{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tansiyon Defteri",
  "version": "0.1.2",
  "identifier": "com.barad21.tansiyon-defteri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tansiyon Defteri",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:tansiyon.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "shortDescription": "Tansiyon ve nabız ölçüm defteri",
    "longDescription": "Sabah ve akşam tansiyon ile nabız ölçümlerini kaydeden ve Excel'e aktaran masaüstü uygulaması."
  }
}
